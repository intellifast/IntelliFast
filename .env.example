# Copy this file to .env on the server and replace both values.
SECRET_KEY=replace-with-a-long-random-secret
APP_ENV=production
APP_BASE_URL=https://your-domain.example
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
BREVO_API_KEY=replace-with-your-brevo-api-key
MAIL_FROM_EMAIL=verified-sender@example.com
MAIL_FROM_NAME=IntelliFast
CRON_SECRET=replace-with-a-long-random-scheduler-secret
